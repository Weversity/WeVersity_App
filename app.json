{
  "expo": {
    "name": "WeVersity",
    "slug": "weversity-expo",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/images/adaptive-icon.png",
    "scheme": "weversityexpo",
    "userInterfaceStyle": "automatic",
    "notifications": {
      "icon": "./assets/images/android-icon-monochrome.png",
      "color": "#8A2BE2"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/ios-dark.png",
      "bundleIdentifier": "org.weversity.app",
      "buildNumber": "25",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.636424335937-a2s6su815jjt90n9561ujagnblb8be16"
            ]
          }
        ]
      },
      "associatedDomains": [
        "applinks:weversity.org"
      ]
    },
    "android": {
      "versionCode": 27,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "org.weversity.app",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "weversity.org",
              "pathPrefix": "/shorts"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosClientId": "636424335937-a2s6su815jjt90n9561ujagnblb8be16.apps.googleusercontent.com",
          "iosUrlScheme": "com.googleusercontent.apps.636424335937-a2s6su815jjt90n9561ujagnblb8be16"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-dark.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-video",
      [
        "expo-build-properties",
        {
          "android": {
            "enablePngCrunchInReleaseBuilds": false,
            "namespace": "org.weversity.app"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bf830a14-3aaf-45e9-bc06-217d3d1ed9ec"
      }
    }
  }
}
